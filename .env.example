# 复制为 .env.local 后本地开发；生产环境在部署平台配置同名变量
# Prisma 使用 postgresql:// 协议（若你之前用 postgresql+psycopg://，请改为标准 URL）
DATABASE_URL="postgresql://postgres.xxxxx:[YOUR_PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 可选：站点绝对地址（https://你的域名），用于 metadata / Open Graph；不设时本地为 http://127.0.0.1:3000，Vercel 会用 VERCEL_URL
NEXT_PUBLIC_APP_URL=""

# AI 模型（基址只填到 /v1，代码会自动拼接 /chat/completions）
# 旧变量名 DASHSCOPE_* 仍可用，但推荐统一用 BAILIAN_*
BAILIAN_API_KEY=""
BAILIAN_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"
BAILIAN_MODEL="qwen3.5-plus"
# 视觉模型（若与文本模型同 key 可不填 BAILIAN_VISION_API_KEY）
BAILIAN_VISION_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
BAILIAN_VISION_API_KEY=""
BAILIAN_VISION_MODEL="qwen-vl-max-latest"

# 可选：仍运行旧版独立 HTTP Agent 时填基址；Next 将 `GET/POST/... /api/agent/**` 转发为 `AGENT_BACKEND_URL/**`（未配置时 `/api/agent/*` 返回 503）
AGENT_BACKEND_URL=""
# 可选：非空则访问 `/api/agent/*` 必须带鉴权（Header `X-MyBroker-Proxy-Key` 或 `?proxy_key=`），且不会把该密钥转发给上游
AGENT_PROXY_SECRET=""

SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="mybroker-screenshots"

REMINDER_PUSH_ENABLED="false"
WEBHOOK_WECOM_URL=""
WEBHOOK_FEISHU_URL=""
WEBHOOK_DINGTALK_URL=""
# 定时调用 /api/cron/push-daily 时需校验（Header Bearer 或 ?secret=）；Vercel 部署同名变量后会自动带 Authorization
CRON_SECRET=""

AUTO_PUSH_DAILY_ENABLED="false"
AUTO_PUSH_DAILY_CHANNEL="wecom"
AUTO_PUSH_DAILY_HOUR="9"
AUTO_PUSH_DAILY_MINUTE="0"
AUTO_PUSH_WEEKDAYS_ONLY="true"

NOTIFY_RETRY_TIMES="2"
NOTIFY_TEMPLATE_HEADER=""
NOTIFY_TEMPLATE_FOOTER=""
NOTIFY_WEEKEND_TEMPLATE_HEADER=""
NOTIFY_WEEKEND_TEMPLATE_FOOTER=""
NOTIFY_FAILURE_TEMPLATE="主渠道发送失败，已尝试降级渠道。请检查 webhook 配置与网络连通性。"
NOTIFY_FALLBACK_CHANNELS="feishu,dingtalk"

NOTIFY_ALERT_ENABLED="false"
NOTIFY_ALERT_THRESHOLD="3"
NOTIFY_ALERT_CRITICAL_THRESHOLD="6"
NOTIFY_ALERT_CHANNEL="wecom"
NOTIFY_ALERT_COOLDOWN_MINUTES="60"
NOTIFY_ALERT_SUPPRESSED_CHANNELS=""

NOTIFY_SELF_HEAL_ENABLED="true"
NOTIFY_SELF_HEAL_PAUSE_MINUTES="30"
NOTIFY_SELF_HEAL_PROBE_ENABLED="true"
NOTIFY_SELF_HEAL_PROBE_INTERVAL_MINUTES="5"

NOTIFY_HEALTH_ALERT_ENABLED="false"
NOTIFY_CHANNEL_HEALTH_ALERT_ENABLED="false"
NOTIFY_HEALTH_WARNING_SCORE="80"
NOTIFY_HEALTH_CRITICAL_SCORE="60"
NOTIFY_HEALTH_CRITICAL_DAYS="3"
